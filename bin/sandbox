#!/usr/bin/env bash

COMMANDS_DIR="/workspace/commands"

NAME=""
SYNTAX=""
DESCRIPTION=""
DETAILS=""

EXAMPLES=()
EXAMPLE_DESCRIPTIONS=()

FLAGS=()
FLAG_DESCRIPTIONS=()

load_command() {
    NAME=""
    SYNTAX=""
    DESCRIPTION=""
    DETAILS=""

    EXAMPLES=()
    EXAMPLE_DESCRIPTIONS=()

    FLAGS=()
    FLAG_DESCRIPTIONS=()

    source "$1"
}

list_commands() {
    for script in "$COMMANDS_DIR"/*.sh; do
        load_command "$script"
        printf "  %-10s %s\n" "$NAME" "$DESCRIPTION"
    done
}

example() {
    EXAMPLES+=("$1")
    EXAMPLE_DESCRIPTIONS+=("$2")
}

flag() {
    FLAGS+=("$1")
    FLAG_DESCRIPTIONS+=("$2")
}

show_example() {
    load_command "$1"
    shift

    echo
    echo "[COMMAND]"
    echo
    echo "\$ $NAME $*"

    echo
    echo "[DESCRIPTION]"
    echo
    echo "$DESCRIPTION"

    local printed=false
    local parsed_flags=()

    for arg in "$@"; do
        [[ "$arg" != -* ]] && continue

        parsed_flags=()

        if [[ "$arg" == --* ]]; then
            parsed_flags+=("$arg")
        else
            local chars="${arg#-}"

            for ((i=0; i<${#chars}; i++)); do
                parsed_flags+=("-${chars:i:1}")
            done
        fi

        for parsed_flag in "${parsed_flags[@]}"; do
            for ((i=0; i<${#FLAGS[@]}; i++)); do
                [[ "${FLAGS[$i]}" == "$parsed_flag" ]] || continue

                if ! $printed; then
                    echo
                    echo "[FLAGS]"
                    echo
                    printed=true
                fi

                printf "  %-8s %s\n" \
                    "$parsed_flag" \
                    "${FLAG_DESCRIPTIONS[$i]}"

                break
            done
        done
    done
}

show_help() {
    load_command "$1"

    echo
    echo "[COMMAND]"
    echo
    echo "$NAME"

    echo
    echo "[SYNTAX]"
    echo
    echo "$SYNTAX"

    echo
    echo "[DESCRIPTION]"
    echo
    echo "$DESCRIPTION"

    echo
    echo "[DETAILS]"
    echo
    echo "$DETAILS"

    if [[ ${#FLAGS[@]} -gt 0 ]]; then
        echo
        echo "[FLAGS]"
        echo

        local width=0

        for flag in "${FLAGS[@]}"; do
            (( ${#flag} > width )) && width=${#flag}
        done

        for ((i=0; i<${#FLAGS[@]}; i++)); do
            printf "  %-*s  %s\n" \
                "$width" \
                "${FLAGS[$i]}" \
                "${FLAG_DESCRIPTIONS[$i]}"
        done
    fi

    if [[ ${#EXAMPLES[@]} -gt 0 ]]; then
        echo
        echo "[EXAMPLES]"
        echo

        local width=0

        for example in "${EXAMPLES[@]}"; do
            (( ${#example} > width )) && width=${#example}
        done

        for ((i=0; i<${#EXAMPLES[@]}; i++)); do
            printf "  %-*s  %s\n" \
                "$width" \
                "${EXAMPLES[$i]}" \
                "${EXAMPLE_DESCRIPTIONS[$i]}"
        done
    fi
}

snapshot() {
    find . | sort
}

new_entries() {
    comm -13 "$1" "$2"
}

execute() {
    local line="$1"

    local cmd="${line%% *}"
    local args=""

    [[ "$line" != "$cmd" ]] && args="${line#"$cmd "}"

    if [[ -n "$args" ]]; then
        read -ra argv <<< "$args"
    else
        argv=()
    fi

    echo
    echo "[RESULT]"
    echo

    if declare -F sandbox_effect >/dev/null; then
        sandbox_effect "${argv[@]}"
    else
        command -p "$cmd" "${argv[@]}"
        echo
    fi
}

case $# in
    0)
        echo "Available commands:"
        list_commands
        ;;

    1)
        SCRIPT="$COMMANDS_DIR/$1.sh"

        [[ -f "$SCRIPT" ]] || {
            echo "Unknown command: $1"
            exit 1
        }

        show_help "$SCRIPT"

        echo

        FIRST_EXAMPLE="${EXAMPLES[0]}"

        if [[ "$FIRST_EXAMPLE" == "$NAME" ]]; then
            execute "$1"
        else
            echo "Add arguments to execute the command, for example:"
            echo "  $FIRST_EXAMPLE"
            echo
        fi
        ;;

    *)
        SCRIPT="$COMMANDS_DIR/$1.sh"

        [[ -f "$SCRIPT" ]] || {
            echo "Unknown command: $1"
            exit 1
        }

        FULL_COMMAND="$*"

        shift
        show_example "$SCRIPT" "$@"

        execute "$FULL_COMMAND"
        ;;
esac
